# =========================================================================
# PLANTILLA DE CONFIGURACIÓN DE PRODUCCIÓN / DESARROLLO (.env.example)
# =========================================================================

# 1. Configuración de Supabase (Obligatorias)
SUPABASE_URL=tu-url-de-supabase
SUPABASE_ANON_KEY=tu-anon-key-de-supabase
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-de-supabase
SUPABASE_PROJECT_ID=tu-project-id-de-supabase

# 2. Configuración de Seguridad (Obligatorias en producción)
JWT_SECRET=genera-un-secret-muy-largo-y-seguro-aqui
CORS_ORIGIN=https://tu-frontend-desplegado.com

# 3. Servidor y Entorno (Recomendadas)
NODE_ENV=production
PORT=3000
API_VERSION=v1

# 4. Parámetros opcionales (tienen valores por defecto)
# SUPABASE_STORAGE_BUCKET=uploads
# JWT_ACCESS_EXPIRATION=15m
# JWT_REFRESH_EXPIRATION=7d
# BCRYPT_ROUNDS=10
# MAX_LOGIN_ATTEMPTS=5
# LOCK_DURATION_MINUTES=30
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# LOG_LEVEL=info
